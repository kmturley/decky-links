{
  "name": "decky-links",
  "version": "0.0.1",
  "description": "Decky Links enables launching games and other URIs on SteamOS by tapping NFC cards",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "debug": "ssh deck@steamdeck.local && journalctl | grep PluginLoader",
    "debug2": "ssh deck@steamdeck.local && cat \"$(ls -t ~/homebrew/logs/decky-links/*.log | head -n 1)\"",
    "deploy": "rsync -rtv --no-perms --no-owner --no-group --chmod=Du=rwx,Dg=rx,Do=rx,Fu=rw,Fg=r,Fo=r --rsh='ssh' ./ deck@steamdeck.local:~/homebrew/plugins/decky-links --exclude .git --exclude node_modules --exclude .venv --exclude .pytest_cache --exclude __pycache__ --exclude .vscode --exclude dist --exclude out --exclude tests --exclude '*.pyc'",
    "stop": "ssh deck@steamdeck.local \"echo 'ssap' | sudo -S systemctl stop plugin_loader\" && ssh deck@steamdeck.local \"echo 'ssap' | sudo -S chown -R deck:deck /home/deck/homebrew/plugins/\"",
    "start": "ssh deck@steamdeck.local \"echo 'ssap' | sudo -S systemctl start plugin_loader\"",
    "watch": "rollup -c -w",
    "test": "PYTHONPATH=. .venv/bin/pytest -q"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kmturley/decky-links.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "deck",
    "nfc",
    "launch"
  ],
  "author": "kmturley",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/kmturley/decky-links/issues"
  },
  "homepage": "https://github.com/kmturley/decky-links#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.3",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}